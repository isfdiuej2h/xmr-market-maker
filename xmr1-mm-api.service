[Unit]
Description=XMR1/USDC Market Maker Dashboard API
After=network.target xmr1-mm-bot.service

[Service]
Type=simple
User=mm
WorkingDirectory=/opt/xmr1-market-maker
EnvironmentFile=/opt/xmr1-market-maker/.env
ExecStart=/opt/xmr1-market-maker/venv/bin/uvicorn api.server:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=xmr1-api

[Install]
WantedBy=multi-user.target
